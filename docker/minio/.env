# MinIO Docker configuration (S3-compatible object storage)
# Image: https://hub.docker.com/r/minio/minio

# Docker Compose
IMAGE_VERSION=minio/minio:RELEASE.2025-09-07T16-13-09Z-cpuv1
SPEC=graflo
CONTAINER_NAME="${SPEC}.minio"

# Host ports (API default 9000, console 9001)
MINIO_API_PORT=9003
MINIO_CONSOLE_PORT=9004

# Root credentials (S3 access key / secret key)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Optional: use from host / apps (e.g. examples/10-tigergraph-bulk-s3, boto3)
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
# MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
# BULK_S3_BUCKET=graflo-staging

# Host API URL (used by MinioConfig.from_docker_env() / boto3; optional MINIO_ENDPOINT overrides)
MINIO_HOSTNAME=127.0.0.1
MINIO_PROTOCOL=http
MINIO_STAGING_BUCKET=graflo-staging
AWS_REGION=us-east-1
MINIO_LOADER_ENDPOINT=http://172.17.0.1:9003
